KEGG modulule dfs + collapse to species level
```{r}

kegg_modules <- c("M00357", "M00567", "M00356", "M00563")
kegg_modules_labels <- c("Methanogenesis, acetate => methane", "Methanogenesis, CO2 => methane", "Methanogenesis, methanol => methane", "Methanogenesis, methylamine/dimethylamine/trimethylamine => methane")


kegg_custom_meso <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/custom/barcode04/kegg/path_abun_contrib.tsv.gz", header = TRUE, sep = "\t") %>%
  filter(function. %in% kegg_modules)


kegg_custom_thermo <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/custom/barcode16/kegg/path_abun_contrib.tsv.gz", header = TRUE, sep = "\t") %>%
  filter(function. %in% kegg_modules)


kegg_standard_meso <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/standard/barcode04/kegg/path_abun_contrib.tsv.gz", header = TRUE, sep = "\t") %>%
  filter(function. %in% kegg_modules)


kegg_standard_thermo <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/standard/barcode16/kegg/path_abun_contrib.tsv.gz", header = TRUE, sep = "\t") %>%
  filter(function. %in% kegg_modules)




# collapse to species level



# 1. KEGG module metadata
# ------------------------------------------------------------------------------

kegg_module_df <- tibble(
  function. = kegg_modules,
  module_label = kegg_modules_labels
)


# 2. Clean taxonomy
# ------------------------------------------------------------------------------

taxonomy_clean <- taxonomy %>%
  mutate(across(everything(), ~ str_trim(.x))) %>%
  rename(taxon = OTU)


# 3. Combine all stratified KEGG module contribution dfs
# ------------------------------------------------------------------------------

kegg_list <- list(
  custom_meso     = kegg_custom_meso,
  custom_thermo   = kegg_custom_thermo,
  standard_meso   = kegg_standard_meso,
  standard_thermo = kegg_standard_thermo
)

kegg_all <- bind_rows(kegg_list, .id = "df_id") %>%
  separate(
    df_id,
    into = c("database", "temperature", "replicate"),
    sep = "_",
    remove = FALSE
  ) %>%
  left_join(kegg_module_df, by = "function.")


# 4. Join taxonomy
# ------------------------------------------------------------------------------

kegg_tax <- kegg_all %>%
  left_join(taxonomy_clean, by = "taxon")


# 5. Collapse to species level
# ------------------------------------------------------------------------------

kegg_species <- kegg_tax %>%
  mutate(
    Species = if_else(
      is.na(Species) | Species == "" | Species == "s__",
      "Unclassified_species",
      Species
    )
  ) %>%
  group_by(
    database,
    temperature,
    replicate,
    sample,
    function.,
    module_label,
    Species
  ) %>%
  summarise(
    taxon_abun = sum(taxon_abun, na.rm = TRUE),
    taxon_rel_abun = sum(taxon_rel_abun, na.rm = TRUE),
    taxon_function_abun = sum(taxon_function_abun, na.rm = TRUE),
    taxon_rel_function_abun = sum(taxon_rel_function_abun, na.rm = TRUE),
    n_asvs = n_distinct(taxon),
    .groups = "drop"
  ) %>%
  group_by(database, temperature, replicate, sample, function.) %>%
  mutate(
    rel_contribution = taxon_function_abun / sum(taxon_function_abun, na.rm = TRUE),
    percent_contribution = 100 * rel_contribution
  ) %>%
  ungroup()




```



