```{r}

setwd("C:/Users/lasse/Desktop/wd/picrust2/my_samples")

library(tidyverse)
library(lubridate)
library(patchwork)



# metadapatchwork# metadata file
metadata <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/metadata.txt", header = TRUE, sep = "\t")

# otutable
otutable <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/FBE62336_otutable_mappedreads.tsv", header = TRUE, sep = "\t")

taxonomy <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/FBE62336_otutable_mappedreads.tsv", header = TRUE, sep = "\t") %>% 
  select(OTU, Kingdom, Phylum, Class, Order, Family, Genus, Species)

barcodes = metadata$barcode

otutable_norm <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/FBE62336_otutable_normalised.tsv", header = TRUE, sep = "\t") %>% 
  select(OTU, FBE62336_barcode04, FBE62336_barcode16)

custom_modules_map <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/custom_module_names.tsv", header = TRUE, sep = "\t")


otutable_norm <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/FBE62336_otutable_normalised.tsv", header = TRUE, sep = "\t")

species_abun <- otutable_norm %>%
  mutate(
    Species = if_else(
      is.na(Species) | Species == "" | Species == "s__",
      "Unclassified_species",
      Species
    )
  ) %>%
  group_by(Species) %>%
  summarise(
    across(all_of(barcodes), ~ sum(.x, na.rm = TRUE)),
    .groups = "drop"
  )


