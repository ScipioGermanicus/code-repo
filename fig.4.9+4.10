NSTI dfs
```{r}

# Weighed NSTI files
weighted_nsti_reference <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/reference/weighted_nsti.tsv", header = TRUE, sep = "\t")


weighted_nsti_standard_meso <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/standard/barcode04/weighted_nsti.tsv.gz", header = TRUE, sep = "\t")


weighted_nsti_standard_thermo <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/standard/barcode16/weighted_nsti.tsv.gz", header = TRUE, sep = "\t")

weighted_nsti_custom_meso <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/custom/barcode04/weighted_nsti.tsv.gz", header = TRUE, sep = "\t")


weighted_nsti_custom_thermo <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/custom/barcode16/weighted_nsti.tsv.gz", header = TRUE, sep = "\t")



# Combine weighted NSTI values

weighted_nsti_all <- bind_rows(
  weighted_nsti_standard_meso   %>% mutate(database = "PICRUSt2-SC",  group = "Mesophilic"),

  weighted_nsti_standard_thermo %>% mutate(database = "PICRUSt2-SC",  group = "Thermophilic"),

  weighted_nsti_custom_meso     %>% mutate(database = "MiDAS DB",    group = "Mesophilic"),

  weighted_nsti_custom_thermo   %>% mutate(database = "MiDAS DB",    group = "Thermophilic"),

  weighted_nsti_reference         %>% mutate(database = "PICRUSt2-SC", group = "Human gut")
) %>%
  mutate(
    plot_group = paste(group, database, sep = " | "),
    plot_group = factor(
      plot_group,
      levels = c(
        "Mesophilic | PICRUSt2-SC",
        "Mesophilic | MiDAS DB",
        "Thermophilic | PICRUSt2-SC",
        "Thermophilic | MiDAS DB",
        "Human gut | PICRUSt2-SC"
      )
    )
  )







id_map <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/id_map.tsv", header = TRUE, sep = "\t")

id_map <- id_map %>%
  mutate(
    original_filename = str_replace(original_filename, "^ZBC", "BC")
  ) %>%
  rename("closest_reference_genome" = "new_id") %>%
  rename("Genome_name" = "original_filename")

# Raw NSTI files

