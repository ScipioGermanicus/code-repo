  left_join(
    kegg_module_df %>%
      rename(pathway = function.),
    by = "pathway"
  ) %>%
  mutate(
    database = str_to_title(database),
    temperature = recode(
      temperature,
      meso = "Mesophilic",
      thermo = "Thermophilic"
    )
  )


