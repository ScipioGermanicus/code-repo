PER-SPECIES CONTRIBUTION (ALL GROUPS)
```{r}

# ------------------------------------------------------------------------------
# 3. Re-collapse to species level
# ------------------------------------------------------------------------------

kegg_species_completeness_filtered <- kegg_tax_completeness_filtered %>%
  mutate(
    Species = if_else(
      is.na(Species) | Species == "" | Species == "s__",
      "Unclassified_species",
      Species
    ),
    Genus = if_else(
      is.na(Genus) | Genus == "" | Genus == "g__",
      "Unclassified_genus",
      Genus
    ),
    Phylum = if_else(
      is.na(Phylum) | Phylum == "" | Phylum == "p__",
      "Unclassified_phylum",
      Phylum
    ),
    Family = if_else(
      is.na(Family) | Family == "" | Family == "f__",
      "Unclassified_family",
      Family
    ),
    Species = str_replace_all(Species, "^s__", ""),
    Genus = str_replace_all(Genus, "^g__", ""),
    Phylum = str_replace_all(Phylum, "^p__", ""),
    Family = str_replace_all(Family, "^f__", ""),
    Species = str_replace_all(Species, "_", " "),
    Genus = str_replace_all(Genus, "_", " "),
    Species = str_squish(Species),
    Genus = str_squish(Genus),
    Phylum = str_squish(Phylum),
    Family = str_squish(Family),
    Species = if_else(
      str_detect(Species, "^midas s [0-9]+$"),
      str_replace_all(Species, " ", "_"),
      Species
    )
  ) %>%
  group_by(
    database,
    temperature,
    sample,
    function.,
    module_label,
    Phylum,
    Family,
    Genus,
    Species
  ) %>%
  summarise(
    taxon_abun = sum(taxon_abun, na.rm = TRUE),
    taxon_rel_abun = sum(taxon_rel_abun, na.rm = TRUE),
    
    taxon_function_abun = sum(taxon_function_abun, na.rm = TRUE),
    taxon_rel_function_abun = sum(taxon_rel_function_abun, na.rm = TRUE),
    
    n_asvs = n_distinct(taxon),
    
    closest_reference_genomes = {
      x <- sort(unique(na.omit(closest_reference_genome_true)))
      if (length(x) == 0) NA_character_ else paste(x, collapse = "; ")
    },
    
    n_closest_reference_genomes = n_distinct(
      closest_reference_genome_true,
      na.rm = TRUE
    ),
    
    mean_NSTI = mean(metadata_NSTI, na.rm = TRUE),
    median_NSTI = median(metadata_NSTI, na.rm = TRUE),
    n_asvs_with_NSTI = sum(!is.na(metadata_NSTI)),
    
    n_asvs_with_complete_closest_MAG = sum(
      database == "custom" & complete_module_in_closest_MAG,
      na.rm = TRUE
    ),
    
    n_asvs_with_incomplete_closest_MAG = sum(
      database == "custom" & !complete_module_in_closest_MAG,
      na.rm = TRUE
    ),
    
    .groups = "drop"
  ) %>%
  mutate(
    mean_NSTI = if_else(is.nan(mean_NSTI), NA_real_, mean_NSTI),
    median_NSTI = if_else(is.nan(median_NSTI), NA_real_, median_NSTI)
  ) %>%
  group_by(database, temperature, sample, function.) %>%
  mutate(
    rel_contribution = {
      total <- sum(taxon_function_abun, na.rm = TRUE)
      if (total > 0) taxon_function_abun / total else rep(0, n())
    },
    percent_contribution = 100 * rel_contribution
  ) %>%
  ungroup()

# ------------------------------------------------------------------------------
# 1. Settings
# ------------------------------------------------------------------------------

top_n_species <- 5

out_base <- "plots_one/completeness_filtered/species_contribution"
dir.create(out_base, recursive = TRUE, showWarnings = FALSE)

# ------------------------------------------------------------------------------
# 2. Pathway groups
# ------------------------------------------------------------------------------

group_methanogenesis <- c(
  "CUS00151",
  "CUS00152",
  "CUS00153",
  "CUS00154",
  "CUS00155"
)

group_VFA_deg <- c(
  "CUS00143",
  "CUS00144",
  "CUS00145",
  "CUS00146"
)

group_acidogenesis <- c(
  "CUS00039",
  "CUS00041",
  "CUS00049",
  "CUS00052",
  "CUS00064",
  "CUS00125",
  "CUS00126",
  "CUS00127",
  "CUS00128",
  "CUS00129",
  "CUS00133",
  "CUS00135",
  "CUS00136",
  "CUS00137",
  "CUS00141"
)

pathway_groups <- list(
  methanogenesis = group_methanogenesis,
  VFA_degradation = group_VFA_deg,
  acidogenesis = group_acidogenesis
)

# ------------------------------------------------------------------------------
# 3. Prepare completeness-filtered species table
# ------------------------------------------------------------------------------

kegg_species_cf <- kegg_species_completeness_filtered %>%
  mutate(
    database = str_to_lower(database),
    temperature = str_to_lower(temperature),
    
    Species_clean = Species,
    Species_clean = if_else(
      is.na(Species_clean) | Species_clean == "",
      "Unclassified_species",
      Species_clean
    ),
    Species_clean = str_squish(Species_clean),
    
    Phylum_clean = Phylum,
    Phylum_clean = if_else(
      is.na(Phylum_clean) | Phylum_clean == "" | Phylum_clean == "p__",
      "unclassified_phylum",
      Phylum_clean
    ),
    Phylum_clean = str_replace_all(Phylum_clean, "^p__", ""),
    Phylum_clean = str_squish(Phylum_clean),
    
    Family_clean = Family,
    Family_clean = if_else(
      is.na(Family_clean) | Family_clean == "" | Family_clean == "f__",
      "unclassified_family",
      Family_clean
    ),
    Family_clean = str_replace_all(Family_clean, "^f__", ""),
    Family_clean = str_squish(Family_clean),
    
    Species_legend = paste0(
      Species_clean,
      " (",
      Phylum_clean,
      "; ",
      Family_clean,
      ")"
    )
  )

# ------------------------------------------------------------------------------
# 4. Create top-5 species dataframe
#    Top 5 are selected separately per module x database x temperature x sample
# ------------------------------------------------------------------------------

top5_species_cf_df <- imap_dfr(pathway_groups, function(pathway_group, group_name) {
  
  kegg_species_cf %>%
    filter(function. %in% pathway_group) %>%
    group_by(
      group = group_name,
      function.,
      module_label,
      database,
      temperature,
      sample,
      Genus,
      Species_clean,
      Phylum_clean,
      Family_clean,
      Species_legend
    ) %>%
    summarise(
      taxon_function_abun = sum(taxon_function_abun, na.rm = TRUE),
      taxon_abun = sum(taxon_abun, na.rm = TRUE),
      n_asvs = sum(n_asvs, na.rm = TRUE),
      closest_reference_genomes = paste(
        sort(unique(unlist(str_split(na.omit(closest_reference_genomes), ";\\s*")))),
        collapse = "; "
      ),
      n_closest_reference_genomes = n_distinct(
        unlist(str_split(na.omit(closest_reference_genomes), ";\\s*"))
      ),
      mean_NSTI = mean(mean_NSTI, na.rm = TRUE),
      median_NSTI = median(median_NSTI, na.rm = TRUE),
      .groups = "drop"
    ) %>%
    mutate(
      closest_reference_genomes = if_else(
        closest_reference_genomes == "",
        NA_character_,
        closest_reference_genomes
      ),
      n_closest_reference_genomes = if_else(
        is.na(closest_reference_genomes),
        0L,
        as.integer(n_closest_reference_genomes)
      ),
      mean_NSTI = if_else(is.nan(mean_NSTI), NA_real_, mean_NSTI),
      median_NSTI = if_else(is.nan(median_NSTI), NA_real_, median_NSTI)
    ) %>%
    group_by(group, function., module_label, database, temperature, sample) %>%
    mutate(
      percent_contribution = {
        total <- sum(taxon_function_abun, na.rm = TRUE)
        if (total > 0) 100 * taxon_function_abun / total else rep(0, n())
      }
    ) %>%
    slice_max(
      order_by = taxon_function_abun,
      n = top_n_species,
      with_ties = FALSE
    ) %>%
    arrange(group, function., database, temperature, sample, desc(taxon_function_abun)) %>%
    ungroup()
})

write.csv(
  top5_species_cf_df,
  file = file.path(out_base, "top5_species_completeness_filtered_per_module_sample.csv"),
  row.names = FALSE
)

# ------------------------------------------------------------------------------
# 5. Function to make stacked barplots from completeness-filtered species data
# ------------------------------------------------------------------------------

make_species_contribution_plots_cf <- function(pathway_group, group_name) {
  
  out_dir <- file.path(out_base, group_name)
  dir.create(out_dir, recursive = TRUE, showWarnings = FALSE)
  
  df_group <- kegg_species_cf %>%
    filter(function. %in% pathway_group)
  
  top_species <- top5_species_cf_df %>%
    filter(group == group_name) %>%
    mutate(is_top_species = TRUE) %>%
    select(
      function.,
      database,
      temperature,
      sample,
      Species_clean,
      Species_legend,
      is_top_species
    )
  
  plot_df <- df_group %>%
    left_join(
      top_species,
      by = c(
        "function.",
        "database",
        "temperature",
        "sample",
        "Species_clean",
        "Species_legend"
      )
    ) %>%
    mutate(
      Species_plot = if_else(is.na(is_top_species), "Other", Species_legend)
    ) %>%
    group_by(
      database,
      temperature,
      sample,
      function.,
      module_label,
      Species_plot
    ) %>%
    summarise(
      taxon_function_abun = sum(taxon_function_abun, na.rm = TRUE),
      .groups = "drop"
    ) %>%
    group_by(database, temperature, sample, function., module_label) %>%
    mutate(
      percent_contribution = {
        total <- sum(taxon_function_abun, na.rm = TRUE)
        if (total > 0) 100 * taxon_function_abun / total else rep(0, n())
      }
    ) %>%
    ungroup() %>%
    mutate(
      sample_group = paste(
        recode(
          temperature,
          meso = "Mesophilic",
          thermo = "Thermophilic"
        ),
        recode(
          database,
          standard = "PICRUSt2-SC",
          custom = "MiDAS DB"
        ),
        sep = " | "
      ),
      sample_group = factor(
        sample_group,
        levels = c(
          "Mesophilic | PICRUSt2-SC",
          "Mesophilic | MiDAS DB",
          "Thermophilic | PICRUSt2-SC",
          "Thermophilic | MiDAS DB"
        )
      ),
      Species_plot = fct_relevel(Species_plot, "Other", after = Inf)
    )
  
  modules_to_plot <- unique(plot_df$function.)
  
  plots <- map(modules_to_plot, function(module_id) {
    
    df_mod <- plot_df %>%
      filter(function. == module_id)
    
    p <- ggplot(
      df_mod,
      aes(
        x = sample_group,
        y = percent_contribution,
        fill = Species_plot
      )
    ) +
      geom_col(width = 0.75, colour = "grey25", linewidth = 0.15) +
      scale_y_continuous(
        limits = c(0, 100),
        expand = expansion(mult = c(0, 0.02))
      ) +
      labs(
        x = NULL,
        y = "Contribution to pathway abundance (%)",
        fill = "Species"
      ) +
      theme_bw(base_size = 12) +
      theme(
        axis.text.x = element_text(angle = 35, hjust = 1, size = 23),
        axis.text.y = element_text(size = 18),
        axis.title = element_text(size = 20),
        panel.grid.major.x = element_blank(),
        panel.grid.minor = element_blank(),
        legend.position = "right",
        legend.title = element_text(face = "bold", size = 22),
        legend.text = element_text(size = 23, face = "italic"),
        strip.text = element_text(size = 20, face = "bold"),
        plot.title = element_text(size = 22, face = "bold"),
        plot.margin = margin(
          t = 0,
          r = 0,
          b = 0,
          l = 140
        )
      )
    
    safe_name <- str_replace_all(module_id, "[^A-Za-z0-9_\\-]", "_")
    
    ggsave(
      filename = file.path(out_dir, paste0(safe_name, "_top5_per_sample_species_contribution_completeness_filtered.png")),
      plot = p,
      width = 16,
      height = 11.6,
      dpi = 300
    )
    
    p
  })
  
  names(plots) <- modules_to_plot
  return(plots)
}

# ------------------------------------------------------------------------------
# 6. Generate plots
# ------------------------------------------------------------------------------

plots_methanogenesis_cf <- make_species_contribution_plots_cf(
  pathway_group = group_methanogenesis,
  group_name = "methanogenesis"
)

plots_VFA_deg_cf <- make_species_contribution_plots_cf(
  pathway_group = group_VFA_deg,
  group_name = "VFA_degradation"
)

plots_acidogenesis_cf <- make_species_contribution_plots_cf(
  pathway_group = group_acidogenesis,
  group_name = "acidogenesis"
)

