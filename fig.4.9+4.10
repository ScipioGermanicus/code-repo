Species contribution
```{r}



# ------------------------------------------------------------------------------
# Species contribution
# ------------------------------------------------------------------------------

library(dplyr)
library(tidyr)
library(stringr)
library(forcats)
library(ggplot2)
library(purrr)

# ------------------------------------------------------------------------------
# 1. Settings
# ------------------------------------------------------------------------------

top_n_species <- 5

out_base <- "plots_one"
dir.create(out_base, recursive = TRUE, showWarnings = FALSE)

target_ecs <- unique(gene_list$EC)

sample_group_levels <- c(
  "Mesophilic | PICRUSt2-SC",
  "Mesophilic | MiDAS DB",
  "Thermophilic | PICRUSt2-SC",
  "Thermophilic | MiDAS DB"
)

# ------------------------------------------------------------------------------
# 2. Combine only the second time point dfs
# ------------------------------------------------------------------------------

ec_list_t2 <- list(
  custom_meso     = ec_custom_meso_2,
  custom_thermo   = ec_custom_thermo_2,
  standard_meso   = ec_standard_meso_2,
  standard_thermo = ec_standard_thermo_2
)

ec_all_t2 <- bind_rows(ec_list_t2, .id = "df_id") %>%
  separate(
    df_id,
    into = c("database", "temperature"),
    sep = "_",
    remove = FALSE
  ) %>%
  filter(function. %in% target_ecs) %>%
  mutate(
    database = str_to_lower(database),
    temperature = str_to_lower(temperature),
    taxon = str_trim(taxon)
  )

# ------------------------------------------------------------------------------
# 3. Add EC labels and taxonomy
# ------------------------------------------------------------------------------

ec_label_df <- gene_list %>%
  distinct(EC, enzyme) %>%
  rename(
    function. = EC,
    ec_label = enzyme
  )

taxonomy_clean <- taxonomy %>%
  mutate(across(everything(), ~ str_trim(.x))) %>%
  rename(taxon = OTU)

ec_species <- ec_all_t2 %>%
  left_join(ec_label_df, by = "function.") %>%
  left_join(taxonomy_clean, by = "taxon") %>%
  mutate(
    Species_clean = Species,
    Species_clean = if_else(
      is.na(Species_clean) | Species_clean == "" | Species_clean == "s__",
      "Unclassified_species",
      Species_clean
    ),
    Species_clean = str_replace_all(Species_clean, "^s__", ""),
    Species_clean = str_squish(Species_clean),
    
    Phylum_clean = Phylum,
    Phylum_clean = if_else(
      is.na(Phylum_clean) | Phylum_clean == "" | Phylum_clean == "p__",
      "unclassified_phylum",
      Phylum_clean
    ),
    Phylum_clean = str_replace_all(Phylum_clean, "^p__", ""),
    Phylum_clean = str_squish(Phylum_clean),
    
    Family_clean = Family,
    Family_clean = if_else(
      is.na(Family_clean) | Family_clean == "" | Family_clean == "f__",
      "unclassified_family",
      Family_clean
    ),
    Family_clean = str_replace_all(Family_clean, "^f__", ""),
    Family_clean = str_squish(Family_clean),
    
    Species_legend = paste0(
      Species_clean,
      " (",
      Phylum_clean,
      "; ",
      Family_clean,
      ")"
    )
  )

# ------------------------------------------------------------------------------
# 4. Collapse to species level
# ------------------------------------------------------------------------------

ec_species_collapsed <- ec_species %>%
  group_by(
    database,
    temperature,
    sample,
    function.,
    ec_label,
    Phylum_clean,
    Family_clean,
    Genus,
    Species_clean,
    Species_legend
  ) %>%
  summarise(
    taxon_function_abun = sum(taxon_function_abun, na.rm = TRUE),
    taxon_abun = sum(taxon_abun, na.rm = TRUE),
    taxon_rel_abun = sum(taxon_rel_abun, na.rm = TRUE),
    n_asvs = n_distinct(taxon),
    .groups = "drop"
  )

# ------------------------------------------------------------------------------
# 5. Select top 5 contributing species per EC x sample group
# ------------------------------------------------------------------------------

top5_ec_species <- ec_species_collapsed %>%
  group_by(
    database,
    temperature,
    sample,
    function.,
    ec_label
  ) %>%
  mutate(
    percent_contribution = {
      total <- sum(taxon_function_abun, na.rm = TRUE)
      if (total > 0) 100 * taxon_function_abun / total else rep(0, n())
    }
  ) %>%
  slice_max(
    order_by = taxon_function_abun,
    n = top_n_species,
    with_ties = FALSE
  ) %>%
  ungroup()

write.csv(
  top5_ec_species,
  file = file.path(out_base, "top5_species_EC_contribution_timepoint2.csv"),
  row.names = FALSE
)

# ------------------------------------------------------------------------------
# 6. Prepare plotting df: top 5 species + Other
# ------------------------------------------------------------------------------

top_species_lookup <- top5_ec_species %>%
  mutate(is_top_species = TRUE) %>%
  select(
    database,
    temperature,
    sample,
    function.,
    Species_clean,
    Species_legend,
    is_top_species
  )

plot_df <- ec_species_collapsed %>%
  left_join(
    top_species_lookup,
    by = c(
      "database",
      "temperature",
      "sample",
      "function.",
      "Species_clean",
      "Species_legend"
    )
  ) %>%
  mutate(
    Species_plot = if_else(is.na(is_top_species), "Other", Species_legend)
  ) %>%
  group_by(
    database,
    temperature,
    sample,
    function.,
    ec_label,
    Species_plot
  ) %>%
  summarise(
    taxon_function_abun = sum(taxon_function_abun, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  group_by(database, temperature, sample, function., ec_label) %>%
  mutate(
    percent_contribution = {
      total <- sum(taxon_function_abun, na.rm = TRUE)
      if (total > 0) 100 * taxon_function_abun / total else rep(0, n())
    }
  ) %>%
  ungroup() %>%
  mutate(
    sample_group = paste(
      recode(
        temperature,
        meso = "Mesophilic",
        thermo = "Thermophilic"
      ),
      recode(
        database,
        standard = "PICRUSt2-SC",
        custom = "MiDAS DB"
      ),
      sep = " | "
    ),
    sample_group = factor(
      sample_group,
      levels = sample_group_levels
    ),
    Species_plot = fct_relevel(Species_plot, "Other", after = Inf)
  )

# ------------------------------------------------------------------------------
# 7. Make one stacked barplot per EC
# ------------------------------------------------------------------------------

make_ec_species_plot <- function(ec_id) {
  
  df_ec <- plot_df %>%
    filter(function. == ec_id)
  
  bar_outline_df <- tibble(
    sample_group = factor(
      sample_group_levels,
      levels = sample_group_levels
    ),
    percent_contribution = 100
  )
  
  p <- ggplot(
    df_ec,
    aes(
      x = sample_group,
      y = percent_contribution,
      fill = Species_plot
    )
  ) +
    geom_col(
      data = bar_outline_df,
      aes(
        x = sample_group,
        y = percent_contribution
      ),
      inherit.aes = FALSE,
      width = 0.75,
      fill = NA,
      colour = "grey25",
      linewidth = 0.15
    ) +
    geom_col(width = 0.75, colour = "grey25", linewidth = 0.15) +
    scale_x_discrete(drop = FALSE) +
    scale_y_continuous(
      limits = c(0, 100),
      expand = expansion(mult = c(0, 0.02))
    ) +
    theme_bw(base_size = 12) +
    labs(
      x = NULL,
      y = "Contribution to EC abundance (%)",
      fill = "Species"
    ) +
    theme(
      axis.text.x = element_text(angle = 35, hjust = 1, size = 20),
      axis.text.y = element_text(size = 16),
      axis.title = element_text(size = 20),
      panel.grid.major.x = element_blank(),
      panel.grid.minor = element_blank(),
      legend.position = "right",
      legend.title = element_text(face = "bold", size = 20),
      legend.text = element_text(size = 18, face = "italic"),
      plot.margin = margin(
        t = 10,
        r = 10,
        b = 0,
        l = 130
      )
    )
  
  safe_name <- str_replace_all(ec_id, "[^A-Za-z0-9_\\-]", "_")
  
  ggsave(
    filename = file.path(
      out_base,
      paste0(safe_name, "_top5_species_EC_contribution_timepoint2.png")
    ),
    plot = p,
    width = 12,
    height = 9,
    dpi = 300
  )
  
  p
}

plots_ec_species <- map(target_ecs, make_ec_species_plot)
names(plots_ec_species) <- target_ecs

plots_ec_species[["3.1.1.11"]]
plots_ec_species[["3.1.1.73"]]


