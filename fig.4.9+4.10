Barplot FAE and PME abundance
```{r}


# ------------------------------------------------------------------------------
# 1. Load data
# ------------------------------------------------------------------------------

gene_list <- read.csv(
  "C:/Users/lasse/Desktop/wd/25/df/26/pectin_deg_genes_reduced.tsv",
  header = TRUE, sep = "\t"
)

ec_custom_meso <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/custom/barcode04/ec/pred_metagenome_contrib.tsv.gz", header = TRUE, sep = "\t") %>%
  filter(function. %in% gene_list$EC)

ec_custom_thermo <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/custom/barcode16/ec/pred_metagenome_contrib.tsv.gz", header = TRUE, sep = "\t") %>%
  filter(function. %in% gene_list$EC)

ec_standard_meso <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/standard/barcode04/ec/pred_metagenome_contrib.tsv.gz", header = TRUE, sep = "\t") %>%
  filter(function. %in% gene_list$EC)

ec_standard_thermo <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/standard/barcode16/ec/pred_metagenome_contrib.tsv.gz", header = TRUE, sep = "\t") %>%
  filter(function. %in% gene_list$EC)

# ------------------------------------------------------------------------------
# 2. Settings
# ------------------------------------------------------------------------------

dir.create("plots/ec", recursive = TRUE, showWarnings = FALSE)

# ------------------------------------------------------------------------------
# 3. EC metadata
# ------------------------------------------------------------------------------

gene_meta <- gene_list %>%
  distinct(EC, enzyme, class, CAZY, KO, substrate, product) %>%
  rename(function. = EC)

# ------------------------------------------------------------------------------
# 4. Combine stratified EC contribution dfs
# ------------------------------------------------------------------------------

ec_list <- list(
  custom_meso     = ec_custom_meso,
  custom_thermo   = ec_custom_thermo,
  standard_meso   = ec_standard_meso,
  standard_thermo = ec_standard_thermo
)

ec_all_strat <- bind_rows(ec_list, .id = "df_id") %>%
  separate(
    df_id,
    into = c("database", "temperature"),
    sep = "_",
    remove = FALSE
  ) %>%
  mutate(
    database = recode(
      database,
      custom = "MiDAS DB",
      standard = "PICRUSt2-SC"
    ),
    temperature = recode(
      temperature,
      meso = "Mesophilic",
      thermo = "Thermophilic"
    ),
    database = factor(
      database,
      levels = c("PICRUSt2-SC", "MiDAS DB")
    ),
    temperature = factor(
      temperature,
      levels = c("Mesophilic", "Thermophilic")
    ),
    plot_group = paste(temperature, database, sep = " | "),
    plot_group = factor(
      plot_group,
      levels = c(
        "Mesophilic | PICRUSt2-SC",
        "Mesophilic | MiDAS DB",
        "Thermophilic | PICRUSt2-SC",
        "Thermophilic | MiDAS DB"
      )
    )
  ) %>%
  left_join(gene_meta, by = "function.")

# ------------------------------------------------------------------------------
# 5. Reconstruct unstratified EC abundance from stratified data
# ------------------------------------------------------------------------------

ec_unstrat_reconstructed <- ec_all_strat %>%
  group_by(
    plot_group,
    database,
    temperature,
    function.,
    enzyme,
    class,
    substrate,
    product
  ) %>%
  summarise(
    abundance = sum(taxon_function_abun, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  mutate(
    ec_label = paste0(function., " — ", enzyme),
    ec_label = str_squish(ec_label)
  ) %>%
  arrange(temperature, database, ec_label)

# ------------------------------------------------------------------------------
# 6. Barplot
# ------------------------------------------------------------------------------

p_ec_barplot <- ggplot(
  ec_unstrat_reconstructed,
  aes(
    x = plot_group,
    y = abundance,
    fill = ec_label
  )
) +
  geom_col(
    width = 0.8,
    colour = "black",
    position = position_dodge2(
      width = 0.8,
      padding = 0,
      preserve = "single"
    )
  ) +
  labs(
    x = NULL,
    y = "Predicted EC abundance (pseudo-log scale)",
    fill = "EC / enzyme"
  ) +
  scale_y_continuous(
    trans = scales::pseudo_log_trans(base = 10),
    breaks = c(0, 10, 10000, 25000, 100000),
    labels = scales::comma
  ) +
  theme_bw(base_size = 18) +
  theme(
    axis.text.x = element_text(angle = 35, hjust = 1, size = 20),
    axis.text.y = element_text(size = 16),
    axis.title = element_text(size = 20),
    panel.grid.major.x = element_blank(),
    panel.grid.minor = element_blank(),
    legend.position = "right",
    legend.title = element_text(face = "bold", size = 20),
    legend.text = element_text(size = 18),
    plot.margin = margin(
      t = 10,
      r = 10,
      b = 0,
      l = 80
    )
  )

p_ec_barplot

# ------------------------------------------------------------------------------
# 7. Save EC abundance barplot
# ------------------------------------------------------------------------------

ggsave(
  filename = "plots_one/ec_custom_standard.png",
  plot = p_ec_barplot,
  width = 13,
  height = 11,
  dpi = 300
)

```
