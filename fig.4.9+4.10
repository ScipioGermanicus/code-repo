```{r}

# ------------------------------------------------------------------------------
# 1. Pathway groups
# ------------------------------------------------------------------------------

group_methanogenesis <- c(
  "CUS00151",
  "CUS00152"
)

group_VFA_deg <- c(
  "CUS00143",
  "CUS00144",
  "CUS00145",
  "CUS00146"
)

group_acidogenesis <- c(
  "CUS00125",
  "CUS00126",
  "CUS00127",
  "CUS00128",
  "CUS00129",
  "CUS00133",
  "CUS00135",
  "CUS00136",
  "CUS00137",
  "CUS00141"
)

# ------------------------------------------------------------------------------
# 2. Metadata
# ------------------------------------------------------------------------------

metadata_clean <- metadata %>%
  mutate(Sampledate = mdy(Sampledate)) %>%
  select(
    sample = barcode,
    Sampledate,
    Reactor_source
  )

# ------------------------------------------------------------------------------
# 3. Reconstruct unstratified module abundance from completeness-filtered
#    species-level stratified data
# ------------------------------------------------------------------------------

meth_barplot_df <- kegg_species_completeness_filtered %>%
  filter(function. %in% group_methanogenesis) %>%
  left_join(metadata_clean, by = "sample") %>%
  mutate(
    database = str_to_title(database),
    temperature = recode(
      temperature,
      meso = "Mesophilic",
      thermo = "Thermophilic"
    ),
    database = recode(
      database,
      "Standard" = "PICRUSt2-SC",
      "Custom" = "MiDAS DB"
    ),
    plot_group = paste(temperature, database, sep = " | "),
    plot_group = factor(
      plot_group,
      levels = c(
        "Mesophilic | PICRUSt2-SC",
        "Mesophilic | MiDAS DB",
        "Thermophilic | PICRUSt2-SC",
        "Thermophilic | MiDAS DB"
      )
    ),
    module_label = factor(
      module_label,
      levels = kegg_module_df %>%
        filter(function. %in% group_methanogenesis) %>%
        pull(module_label)
    )
  ) %>%
  filter(!is.na(plot_group)) %>%
  group_by(plot_group, database, temperature, function., module_label) %>%
  summarise(
    abundance = sum(taxon_function_abun, na.rm = TRUE),
    .groups = "drop"
  )

# ------------------------------------------------------------------------------
# 4. Plot pathway/module dominance
# ------------------------------------------------------------------------------

p_methanogenesis_barplot <- ggplot(
  meth_barplot_df,
  aes(
    x = plot_group,
    y = abundance,
    fill = module_label
  )
) +
  geom_col(
    width = 0.8,
    colour = "black",
    position = position_dodge2(
      width = 0.8,
      padding = 0,
      preserve = "single"
    )
  ) +
  scale_y_continuous(
  trans = "pseudo_log",
  limits = c(0, 90000),
  breaks = c(
    0,
    2000,
    40000,
    80000
  )
) +
  labs(
    x = NULL,
    y = "Predicted pathway abundance (pseudo-log scale)",
    fill = "Module"
  ) +
  theme_bw(base_size = 18) +
  theme(
    axis.text.x = element_text(angle = 35, hjust = 1, size = 23),
    axis.text.y = element_text(size = 18),
    axis.title = element_text(size = 20),
    legend.title = element_text(face = "bold", size = 20),
    legend.text = element_text(size = 20),
    panel.grid.major.x = element_blank(),
    panel.grid.minor = element_blank(),
    plot.margin = margin(
      t = 10,
      r = 10,
      b = 0,
      l = 120
    )
  )

