...... KEGG MODULE ABUNDANCE .......

Pathway dominance METHANOGENESIS (ONLY ACET. METH AND HYD. METH)
```{r}

group_methanogenesis <- c("CUS00151", "CUS00152")

# ------------------------------------------------------------------------------
# 1. Convert unstratified table to long format
# ------------------------------------------------------------------------------

kegg2_all_unstrat_long <- kegg2_all_unstrat %>%
  pivot_longer(
    cols = starts_with("FBE62336_"),
    names_to = "sample",
    values_to = "abundance",
    values_drop_na = TRUE
  ) %>%
  mutate(
    abundance = as.numeric(abundance),
    database = recode(
      database,
      "Standard" = "PICRUSt2-SC",
      "Custom" = "MiDAS DB"
    ),
    plot_group = paste(temperature, database, sep = " | "),
    plot_group = factor(
      plot_group,
      levels = c(
        "Mesophilic | PICRUSt2-SC",
        "Mesophilic | MiDAS DB",
        "Thermophilic | PICRUSt2-SC",
        "Thermophilic | MiDAS DB"
      )
    )
  )

# ------------------------------------------------------------------------------
# 2. Summarise pathway abundance
# ------------------------------------------------------------------------------

meth_barplot_df <- kegg2_all_unstrat_long %>%
  filter(pathway %in% group_methanogenesis) %>%
  mutate(
    module_label = factor(
      module_label,
      levels = kegg_module_df %>%
        filter(function. %in% group_methanogenesis) %>%
        pull(module_label)
    )
  ) %>%
  group_by(plot_group, database, temperature, pathway, module_label) %>%
  summarise(
    mean_abundance = mean(abundance, na.rm = TRUE),
    sd_abundance = sd(abundance, na.rm = TRUE),
    .groups = "drop"
  )

# ------------------------------------------------------------------------------
# 3. Barplot
# ------------------------------------------------------------------------------

p_methanogenesis_barplot <- ggplot(
  meth_barplot_df,
  aes(
    x = plot_group,
    y = mean_abundance,
    fill = module_label
  )
) +
  geom_col(
    width = 0.8,
    colour = "black",
    position = position_dodge2(
      width = 0.8,
      padding = 0,
      preserve = "single"
    )
  ) +
  geom_errorbar(
    aes(
      ymin = mean_abundance - sd_abundance,
      ymax = mean_abundance + sd_abundance,
      group = module_label
    ),
    width = 0.15,
    position = position_dodge2(
      width = 0.8,
      padding = 0,
      preserve = "single"
    )
  ) +
  labs(
    x = NULL,
    y = "Predicted pathway abundance",
    fill = "Module"
  ) +
  theme_bw(base_size = 18) +
  theme(
    axis.text.x = element_text(angle = 35, hjust = 1, size = 23),
    axis.text.y = element_text(size = 18),
    axis.title = element_text(size = 20),
    legend.title = element_text(face = "bold", size = 20),
    legend.text = element_text(size = 20),
    panel.grid.major.x = element_blank(),
