# ------------------------------------------------------------------------------
# 1. KEGG modules
# ------------------------------------------------------------------------------

kegg_modules <- c(
  "CUS00151", "CUS00152", "CUS00153", "CUS00154", "CUS00155",
  "CUS00039", "CUS00041", "CUS00049", "CUS00052", "CUS00064",
  "CUS00065", "CUS00066", "CUS00067", "CUS00068", "CUS00069",
  "CUS00125", "CUS00126", "CUS00127", "CUS00128", "CUS00129",
  "CUS00133", "CUS00135", "CUS00136", "CUS00137", "CUS00141",
  "CUS00142", "CUS00143", "CUS00144", "CUS00145", "CUS00146"
)

kegg_modules_labels <- c(
  "Methanogenesis I, acetate => methane",
  "Methanogenesis II, CO2 => methane",
  "Methanogenesis III, methanol => methane",
  "Methanogenesis IV, methylamine => methane",
  "Methanogenesis V, methanethiol => methane",
  "Isoleucine degradation II, isoleucine => 2-methylbutyrate",
  "Leucine degradation II, leucine => 3-methylbutyrate",
  "Methionine degradation II, L-methionine => 2-oxobutanoate",
  "Proline degradation II, L-proline => 5-aminovalerate",
  "Valine degradation II, L-valine => 2-methylpropanoate",
  "Glycerol degradation I, glycerol => sn-glycerol 3-phosphate => glycerone-P",
  "Glycerol degradation II, glycerol => dihydroxyacetone => glycerone-P",
  "Glycerol degradation III, glycerol => 1,3-Propanediol",
  "Long chain fatty acid beta-oxidation, LFCAs => Acetyl-CoA",
  "Triacylglycerol degradation, triacylglycerol => glycerol + fatty acid",
  "Acetyl-CoA fermentation to acetate, acetyl-CoA => acetate",
  "Acetyl-CoA fermentation to acetate, acetyl-CoA => acetate and formate",
  "Acetyl-CoA fermentation to succinate and acetate",
  "Pyruvate fermentation to acetate and lactate",
  "Pyruvate fermentation to lactate",
  "Lactate degradation lactate => propionate",
  "Acetyl-CoA fermentation to butanoate I",
  "Acetyl-CoA fermentation to butanoate II",
  "Succinate fermentation to butanoate",
  "Methylmalonyl-CoA pathway (from succinyl-CoA to propanoate)",
  "Reductive acetyl-CoA pathway (Wood-Ljungdahl pathway)",
  "Syntrophic butyrate degradation, butyrate => acetyl-CoA",
  "Syntrophic propionate degradation, propionate => acetate",
  "Reversed WL pathway acetate => CO2",
  "WLP-GCS pathway acetate => CO2"
)

kegg_module_df <- tibble(
  function. = kegg_modules,
  module_label = kegg_modules_labels
)

# ------------------------------------------------------------------------------
# 2. Read stratified KEGG contribution files
# ------------------------------------------------------------------------------


kegg2_custom_meso <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/custom/barcode04/kegg2/path_abun_contrib.tsv.gz", header = TRUE, sep = "\t") %>%
  filter(function. %in% kegg_modules)


kegg2_custom_thermo <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/custom/barcode16/kegg2/path_abun_contrib.tsv.gz", header = TRUE, sep = "\t") %>%
  filter(function. %in% kegg_modules)


kegg2_standard_meso <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/standard/barcode04/kegg2/path_abun_contrib.tsv.gz", header = TRUE, sep = "\t") %>%
  filter(function. %in% kegg_modules)


kegg2_standard_thermo <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/standard/barcode16/kegg2/path_abun_contrib.tsv.gz", header = TRUE, sep = "\t") %>%
  filter(function. %in% kegg_modules)

# ------------------------------------------------------------------------------
# 3. Combine KEGG contribution files
# ------------------------------------------------------------------------------

kegg_list <- list(
  custom_meso     = kegg2_custom_meso,
  custom_thermo   = kegg2_custom_thermo,
  standard_meso   = kegg2_standard_meso,
  standard_thermo = kegg2_standard_thermo
)

kegg_all <- bind_rows(kegg_list, .id = "df_id") %>%
  separate(
    df_id,
    into = c("database", "temperature"),
    sep = "_",
    remove = FALSE
  ) %>%
  mutate(
    database = str_to_lower(database),
    temperature = str_to_lower(temperature),
    taxon = str_trim(taxon)
  ) %>%
  left_join(kegg_module_df, by = "function.")

# ------------------------------------------------------------------------------
# 4. Clean taxonomy
# ------------------------------------------------------------------------------

taxonomy_clean <- taxonomy %>%
  mutate(across(everything(), ~ str_trim(.x))) %>%
  rename(taxon = OTU)

# ------------------------------------------------------------------------------
# 5. Combine custom NSTI dfs and retain true closest reference genome name
# ------------------------------------------------------------------------------

nsti_custom_list <- list(
  custom_meso   = nsti_custom_meso,
  custom_thermo = nsti_custom_thermo
)

custom_closest_ref <- bind_rows(nsti_custom_list, .id = "df_id") %>%
  separate(
    df_id,
    into = c("database", "temperature"),
    sep = "_",
    remove = FALSE
  ) %>%
  transmute(
    database = str_to_lower(database),
    temperature = str_to_lower(temperature),
    taxon = str_trim(sequence),
    closest_reference_genome_true = str_trim(Genome_name),
    metadata_NSTI = as.numeric(metadata_NSTI)
  ) %>%
  distinct(
    database,
    temperature,
    taxon,
    closest_reference_genome_true,
    metadata_NSTI
  )

# ------------------------------------------------------------------------------
# 6. Join taxonomy and closest-reference-genome information at ASV level
# ------------------------------------------------------------------------------

kegg_tax <- kegg_all %>%
  left_join(taxonomy_clean, by = "taxon") %>%
  left_join(
    custom_closest_ref,
    by = c("database", "temperature", "taxon")
  )

# ------------------------------------------------------------------------------
# 1. Clean EnrichM completeness table
# ------------------------------------------------------------------------------

completeness <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/floodgate/df/module_completeness.tsv", header = TRUE, sep = "\t")

completeness_f <- completeness %>%
  filter(Module_id %in% kegg_modules_labels)

completeness_clean <- completeness_f %>%
  mutate(
    Genome_name_clean = str_remove(Genome_name, "\\.fa$"),
    Module_id = str_squish(Module_id)
  ) %>%
  select(
    Genome_name_clean,
    module_label = Module_id,
    Percent_steps_found
  )

# ------------------------------------------------------------------------------
# 2. Apply completeness filter at ASV level
# ------------------------------------------------------------------------------

kegg_tax_completeness_filtered <- kegg_tax %>%
  mutate(
    database = str_to_lower(database),
    temperature = str_to_lower(temperature),
    Genome_name_clean = str_remove(closest_reference_genome_true, "\\.fa$"),
    module_label = str_squish(module_label)
  ) %>%
  left_join(
    completeness_clean,
    by = c(
      "Genome_name_clean",
      "module_label"
    )
  ) %>%
  mutate(
    complete_module_in_closest_MAG = Percent_steps_found == 100,
    
    # conservative: custom rows with missing completeness are treated as incomplete
    complete_module_in_closest_MAG = if_else(
      database == "custom" & is.na(complete_module_in_closest_MAG),
      FALSE,
      complete_module_in_closest_MAG
    ),
    
    taxon_function_abun = if_else(
      database == "custom" & !complete_module_in_closest_MAG,
      0,
      taxon_function_abun
    ),
    
    taxon_rel_function_abun = if_else(
      database == "custom" & !complete_module_in_closest_MAG,
      0,
      taxon_rel_function_abun
    ),
    
    genome_function_count = if_else(
      database == "custom" & !complete_module_in_closest_MAG,
      0,
      genome_function_count
    )
  )

# If this column exists in your table, zero it too
if ("norm_taxon_function_contrib" %in% colnames(kegg_tax_completeness_filtered)) {
  kegg_tax_completeness_filtered <- kegg_tax_completeness_filtered %>%
    mutate(
      norm_taxon_function_contrib = if_else(
        database == "custom" & !complete_module_in_closest_MAG,
        0,
        norm_taxon_function_contrib
      )
    )
}

# ------------------------------------------------------------------------------
# 3. Re-collapse to species level
# ------------------------------------------------------------------------------

kegg_species_completeness_filtered <- kegg_tax_completeness_filtered %>%
  mutate(
    Species = if_else(
      is.na(Species) | Species == "" | Species == "s__",
      "Unclassified_species",
      Species
    ),
    Genus = if_else(
      is.na(Genus) | Genus == "" | Genus == "g__",
      "Unclassified_genus",
      Genus
    ),
    Species = str_replace_all(Species, "^s__", ""),
    Genus = str_replace_all(Genus, "^g__", ""),
    Species = str_replace_all(Species, "_", " "),
    Genus = str_replace_all(Genus, "_", " "),
    Species = str_squish(Species),
    Genus = str_squish(Genus),
    Species = if_else(
      str_detect(Species, "^midas s [0-9]+$"),
      str_replace_all(Species, " ", "_"),
      Species
    )
  ) %>%
  group_by(
    database,
    temperature,
    sample,
    function.,
    module_label,
    Genus,
    Species
  ) %>%
  summarise(
    taxon_abun = sum(taxon_abun, na.rm = TRUE),
    taxon_rel_abun = sum(taxon_rel_abun, na.rm = TRUE),
    
    taxon_function_abun = sum(taxon_function_abun, na.rm = TRUE),
    taxon_rel_function_abun = sum(taxon_rel_function_abun, na.rm = TRUE),
    
    n_asvs = n_distinct(taxon),
    
    closest_reference_genomes = {
      x <- sort(unique(na.omit(closest_reference_genome_true)))
      if (length(x) == 0) NA_character_ else paste(x, collapse = "; ")
    },
    
    n_closest_reference_genomes = n_distinct(
      closest_reference_genome_true,
      na.rm = TRUE
    ),
    
    mean_NSTI = mean(metadata_NSTI, na.rm = TRUE),
    median_NSTI = median(metadata_NSTI, na.rm = TRUE),
    n_asvs_with_NSTI = sum(!is.na(metadata_NSTI)),
    
    n_asvs_with_complete_closest_MAG = sum(
      database == "custom" & complete_module_in_closest_MAG,
      na.rm = TRUE
    ),
    
    n_asvs_with_incomplete_closest_MAG = sum(
      database == "custom" & !complete_module_in_closest_MAG,
      na.rm = TRUE
    ),
    
    .groups = "drop"
  ) %>%
  mutate(
    mean_NSTI = if_else(is.nan(mean_NSTI), NA_real_, mean_NSTI),
    median_NSTI = if_else(is.nan(median_NSTI), NA_real_, median_NSTI)
  ) %>%
  group_by(database, temperature, sample, function.) %>%
  mutate(
    rel_contribution = {
      total <- sum(taxon_function_abun, na.rm = TRUE)
      if (total > 0) taxon_function_abun / total else rep(0, n())
    },
    percent_contribution = 100 * rel_contribution
  ) %>%
  ungroup()





