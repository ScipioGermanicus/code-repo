nsti_standard_thermo <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/standard/barcode16/combined_marker_predicted_and_nsti.tsv.gz", header = TRUE, sep = "\t")


nsti_custom_meso <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/custom/barcode04/combined_marker_predicted_and_nsti.tsv.gz", header = TRUE, sep = "\t") %>%
  left_join(id_map, by = ("closest_reference_genome"))


nsti_custom_thermo <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/my_samples/custom/barcode16/combined_marker_predicted_and_nsti.tsv.gz", header = TRUE, sep = "\t") %>%
  left_join(id_map, by = ("closest_reference_genome"))



nsti_reference <- read.csv("C:/Users/lasse/Desktop/wd/picrust2/df/gut_data/combined_marker_predicted_and_nsti.tsv", header = TRUE, sep = "\t")



# ------------------------------------------------------------------------------
# 1. Combine stratified NSTI values
# ------------------------------------------------------------------------------

nsti_all <- bind_rows(
  nsti_standard_meso   %>% mutate(database = "PICRUSt2-SC", group = "Mesophilic"),

  nsti_standard_thermo %>% mutate(database = "PICRUSt2-SC", group = "Thermophilic"),

  nsti_custom_meso     %>% mutate(database = "MiDAS DB", group = "Mesophilic"),

  nsti_custom_thermo   %>% mutate(database = "MiDAS DB", group = "Thermophilic"),
) %>%
  mutate(
    plot_group = paste(group, database, sep = " | "),
    plot_group = factor(
      plot_group,
      levels = c(
        "Mesophilic | PICRUSt2-SC",
        "Mesophilic | MiDAS DB",
        "Thermophilic | PICRUSt2-SC",
        "Thermophilic | MiDAS DB"
      )
    )
  )

# ------------------------------------------------------------------------------
# 2. Summary dataframe for stratified NSTI values
# ------------------------------------------------------------------------------

nsti_summary <- nsti_all %>%
  group_by(plot_group, database, group) %>%
  summarise(
    mean_NSTI = mean(metadata_NSTI, na.rm = TRUE),
    median_NSTI = median(metadata_NSTI, na.rm = TRUE),
    sd_NSTI = sd(metadata_NSTI, na.rm = TRUE),
    min_NSTI = min(metadata_NSTI, na.rm = TRUE),
    max_NSTI = max(metadata_NSTI, na.rm = TRUE),
    n_OTUs = n(),
    .groups = "drop"
  )


