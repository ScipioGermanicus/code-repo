...... KEY SPECIES AND THEIR NSTI .......

Strat path abun contrib stacked barplot (KEGG)
```{r}

group_methanogenesis <- c("CUS00151", "CUS00152", "CUS00153", "CUS00154", "CUS00155")

group_VFA_deg <- c("CUS00143", "CUS00144", "CUS00145", "CUS00146")

group_acidogenesis <- c("CUS00039", "CUS00041", "CUS00049", "CUS00052", "CUS00064", "CUS00125", "CUS00126", "CUS00127", "CUS00128", "CUS00129", "CUS00133", "CUS00135", "CUS00136", "CUS00137", "CUS00141")


library(tidyverse)
library(ggplot2)

# ------------------------------------------------------------------------------
# 1. Settings
# ------------------------------------------------------------------------------

top_n_species <- 5

out_base <- "plots_one/kegg/species_contribution"
dir.create(out_base, recursive = TRUE, showWarnings = FALSE)

# ------------------------------------------------------------------------------
# 2. Combine NSTI dfs
# ------------------------------------------------------------------------------

nsti_list <- list(
  custom_meso     = nsti_custom_meso,
  custom_thermo   = nsti_custom_thermo,
  standard_meso   = nsti_standard_meso,
  standard_thermo = nsti_standard_thermo
)

nsti_all <- bind_rows(nsti_list, .id = "df_id") %>%
  separate(
    df_id,
    into = c("database", "temperature"),
    sep = "_",
    remove = FALSE
  ) %>%
  transmute(
    database = str_to_lower(database),
    temperature = str_to_lower(temperature),
    taxon = str_trim(sequence),
    NSTI = as.numeric(metadata_NSTI)
  )

# ------------------------------------------------------------------------------
# 3. Join NSTI to ASV-level KEGG contribution table
# ------------------------------------------------------------------------------

kegg_tax_nsti <- kegg_tax %>%
  mutate(
    taxon = str_trim(taxon),
    database = str_to_lower(database),
    temperature = str_to_lower(temperature)
  ) %>%
  left_join(
    nsti_all,
    by = c("database", "temperature", "taxon")
  ) %>%
  mutate(
    Species_clean = case_when(
      is.na(Species) | Species == "" | Species == "s__" ~ paste0(Genus, "_unclassified_species"),
      TRUE ~ Species
    ),
    Species_clean = str_replace_all(Species_clean, "^s__", ""),
    Species_clean = str_replace_all(Species_clean, "^g__", ""),
    
    Phylum_clean = case_when(
      is.na(Phylum) | Phylum == "" | Phylum == "p__" ~ "unclassified_phylum",
      TRUE ~ Phylum
    ),
    Phylum_clean = str_replace_all(Phylum_clean, "^p__", ""),
    
    Family_clean = case_when(
      is.na(Family) | Family == "" | Family == "f__" ~ "unclassified_family",
      TRUE ~ Family
    ),
    Family_clean = str_replace_all(Family_clean, "^f__", ""),
    
    Species_legend = paste0(
      Species_clean,
      " (",
      Phylum_clean,
      "; ",
      Family_clean,
      ")"
    )
  )

# ------------------------------------------------------------------------------
# 4. Define group metadata
# ------------------------------------------------------------------------------

pathway_groups <- list(
  methanogenesis = group_methanogenesis,
  VFA_degradation = group_VFA_deg,
  acidogenesis = group_acidogenesis
)

# ------------------------------------------------------------------------------
# 5. Create top-5 NSTI dataframe
# ------------------------------------------------------------------------------

top5_species_nsti_df <- imap_dfr(pathway_groups, function(pathway_group, group_name) {
  
  kegg_tax_nsti %>%
    filter(function. %in% pathway_group) %>%
    group_by(
      group = group_name,
      function.,
      module_label,
      database,
      temperature,
      sample,
      Phylum_clean,
      Family_clean,
      Species_clean,
      Species_legend
    ) %>%
    summarise(
      taxon_function_abun = sum(taxon_function_abun, na.rm = TRUE),
      mean_NSTI = mean(NSTI, na.rm = TRUE),
      median_NSTI = median(NSTI, na.rm = TRUE),
      min_NSTI = min(NSTI, na.rm = TRUE),
      max_NSTI = max(NSTI, na.rm = TRUE),
      n_asvs = n_distinct(taxon),
      n_asvs_with_NSTI = sum(!is.na(NSTI)),
      .groups = "drop"
    ) %>%
    mutate(
      mean_NSTI = if_else(is.nan(mean_NSTI), NA_real_, mean_NSTI),
      median_NSTI = if_else(is.nan(median_NSTI), NA_real_, median_NSTI),
      min_NSTI = if_else(is.infinite(min_NSTI), NA_real_, min_NSTI),
      max_NSTI = if_else(is.infinite(max_NSTI), NA_real_, max_NSTI)
    ) %>%
    group_by(group, function., module_label, database, temperature, sample) %>%
    mutate(
      percent_contribution = 100 * taxon_function_abun / sum(taxon_function_abun, na.rm = TRUE)
    ) %>%
    slice_max(
      order_by = taxon_function_abun,
      n = top_n_species,
      with_ties = FALSE
    ) %>%
    arrange(group, function., database, temperature, sample, desc(taxon_function_abun)) %>%
    ungroup()
})

write.csv(
  top5_species_nsti_df,
  file = file.path(out_base, "top5_species_mean_NSTI_per_module_sample.csv"),
  row.names = FALSE
)

# ------------------------------------------------------------------------------
# 6. Function to make stacked barplots without NSTI labels
# ------------------------------------------------------------------------------

make_species_contribution_plots <- function(pathway_group, group_name) {
  
  out_dir <- file.path(out_base, group_name)
  dir.create(out_dir, recursive = TRUE, showWarnings = FALSE)
  
  df_group <- kegg_tax_nsti %>%
    filter(function. %in% pathway_group)
  
  top_species <- top5_species_nsti_df %>%
    filter(group == group_name) %>%
    mutate(is_top_species = TRUE) %>%
    select(
      function.,
      database,
      temperature,
      sample,
      Species_clean,
      Species_legend,
      is_top_species
    )
  
  plot_df <- df_group %>%
    left_join(
      top_species,
      by = c(
        "function.",
        "database",
        "temperature",
        "sample",
        "Species_clean",
        "Species_legend"
      )
    ) %>%
    mutate(
      Species_plot = if_else(is.na(is_top_species), "Other", Species_legend)
    ) %>%
    group_by(
      database,
      temperature,
      sample,
      function.,
      module_label,
      Species_plot
    ) %>%
    summarise(
      taxon_function_abun = sum(taxon_function_abun, na.rm = TRUE),
      .groups = "drop"
    ) %>%
    group_by(database, temperature, sample, function., module_label) %>%
    mutate(
      percent_contribution = 100 * taxon_function_abun / sum(taxon_function_abun, na.rm = TRUE)
    ) %>%
    ungroup() %>%
    mutate(
      sample_group = paste(
        recode(
          temperature,
          meso = "Mesophilic",
          thermo = "Thermophilic"
        ),
        recode(
          database,
          standard = "PICRUSt2-SC",
          custom = "MiDAS DB"
        ),
        sep = " | "
      ),
      sample_group = factor(
        sample_group,
        levels = c(
          "Mesophilic | PICRUSt2-SC",
          "Mesophilic | MiDAS DB",
          "Thermophilic | PICRUSt2-SC",
          "Thermophilic | MiDAS DB"
        )
      ),
      Species_plot = factor(
        Species_plot,
        levels = c(
          setdiff(unique(Species_plot), "Other"),
          "Other"
        )
      )
    )
  
  modules_to_plot <- unique(plot_df$function.)
  
  plots <- map(modules_to_plot, function(module_id) {
    
    df_mod <- plot_df %>%
      filter(function. == module_id)
    
    module_title <- df_mod %>%
      distinct(module_label) %>%
      pull(module_label) %>%
      first()
    
    p <- ggplot(
      df_mod,
      aes(
        x = sample_group,
        y = percent_contribution,
        fill = Species_plot
      )
    ) +
      geom_col(width = 0.75, colour = "grey25", linewidth = 0.15) +
      scale_y_continuous(
        limits = c(0, 100),
        expand = expansion(mult = c(0, 0.02))
      ) +
      labs(
        x = NULL,
        y = "Contribution to pathway abundance (%)",
        fill = "Species"
      ) +
      theme_bw(base_size = 20) +
      theme(
        axis.text.x = element_text(angle = 35, hjust = 1, size = 23),
        axis.text.y = element_text(size = 18),
        axis.title = element_text(size = 20),
        panel.grid.major.x = element_blank(),
        panel.grid.minor = element_blank(),
        legend.position = "right",
        legend.title = element_text(face = "bold", size = 22),
        legend.text = element_text(size = 22, face = "italic"),
        strip.text = element_text(size = 20, face = "bold"),
        plot.title = element_text(size = 22, face = "bold"),
        plot.margin = margin(
          t = 0,
          r = 0,
          b = 0,
          l = 130
        )
      ) +
      guides(
        fill = guide_legend(
          ncol = 1
        )
      )
    
    safe_name <- str_replace_all(module_id, "[^A-Za-z0-9_\\-]", "_")
    
    ggsave(
      filename = file.path(out_dir, paste0(safe_name, "_top5_per_sample_species_contribution.png")),
      plot = p,
      width = 15,
      height = 11.6,
      dpi = 300
    )
    
    p
  })
  
  names(plots) <- modules_to_plot
  return(plots)
}

# ------------------------------------------------------------------------------
# 7. Generate plots
# ------------------------------------------------------------------------------

plots_methanogenesis <- make_species_contribution_plots(
  pathway_group = group_methanogenesis,
  group_name = "methanogenesis"
)

plots_VFA_deg <- make_species_contribution_plots(
  pathway_group = group_VFA_deg,
  group_name = "VFA_degradation"
)

plots_acidogenesis <- make_species_contribution_plots(
  pathway_group = group_acidogenesis,
  group_name = "acidogenesis"
)

meth <- kegg_species %>%
  filter(function. == "CUS00151")

