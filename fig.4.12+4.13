NSTI barplot
```{r}

library(tidyverse)

# Combine weighted NSTI values
weighted_nsti_all <- bind_rows(
  nsti_crashed_barcode08 %>% mutate(group = "Crashed"),
  nsti_crashed_barcode55 %>% mutate(group = "Crashed"),
  nsti_crashed_barcode67 %>% mutate(group = "Crashed"),
  nsti_crashed_barcode79 %>% mutate(group = "Crashed"),
  nsti_crashed_barcode91 %>% mutate(group = "Crashed"),
  
  nsti_healthy_barcode20 %>% mutate(group = "Healthy"),
  nsti_healthy_barcode32 %>% mutate(group = "Healthy"),
  nsti_healthy_barcode44 %>% mutate(group = "Healthy"),
  nsti_healthy_barcode56 %>% mutate(group = "Healthy"),
  abun_healthy_barcode68 %>% mutate(group = "Healthy"),
  
  weighted_nsti_reference %>% mutate(group = "Reference")
) %>%
  mutate(
    group = factor(group, levels = c("Crashed", "Healthy", "Reference"))
  )

# Summarise mean weighted NSTI per group
weighted_nsti_summary <- weighted_nsti_all %>%
  group_by(group) %>%
  summarise(
    mean_weighted_NSTI = mean(weighted_NSTI, na.rm = TRUE),
    sd_weighted_NSTI   = sd(weighted_NSTI, na.rm = TRUE),
    n                  = n(),
    se_weighted_NSTI   = sd_weighted_NSTI / sqrt(n),
    .groups = "drop"
  )

# Barplot
p <- ggplot(weighted_nsti_summary, aes(x = group, y = mean_weighted_NSTI, fill = group)) +
  geom_col(width = 0.7, colour = "black", linewidth = 0.3) +
  geom_errorbar(
    aes(
      ymin = mean_weighted_NSTI - se_weighted_NSTI,
      ymax = mean_weighted_NSTI + se_weighted_NSTI
    ),
    width = 0.2,
    linewidth = 0.4
  ) +
  geom_point(
    data = weighted_nsti_all,
    aes(x = group, y = weighted_NSTI),
    inherit.aes = FALSE,
    position = position_jitter(width = 0.08, height = 0),
    size = 2,
    alpha = 0.8
  ) +
  labs(
    x = NULL,
    y = "Weighted NSTI",
    fill = NULL
  ) +
  theme_bw() +
  theme(
    legend.position = "none",
    axis.text.x = element_text(size = 11),
    axis.text.y = element_text(size = 10),
    axis.title.y = element_text(size = 12),
    panel.grid.major.x = element_blank()
  )

p

ggsave(
  filename = "weighted_nsti_group_barplot.png",
  plot = p,
  width = 6,
  height = 4,
  dpi = 300
)



