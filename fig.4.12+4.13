pathway dominance plot
```{r}

# ------------------------------------------------------------------------------
# 1. Define pathway groups
# ------------------------------------------------------------------------------

group_methanogenesis <- c(
  "CUS00151", "CUS00152", "CUS00153", "CUS00154", "CUS00155"
)

group_VFA_deg <- c(
  "CUS00142", "CUS00143", "CUS00144", "CUS00145", "CUS00146"
)

group_acidogenesis <- c(
  "CUS00125", "CUS00126", "CUS00127", "CUS00128", "CUS00129",
  "CUS00133", "CUS00135", "CUS00136", "CUS00137", "CUS00141"
)

pathway_groups <- tibble(
  function. = c(group_methanogenesis, group_VFA_deg, group_acidogenesis),
  pathway_group = c(
    rep("Methanogenesis", length(group_methanogenesis)),
    rep("VFA degradation", length(group_VFA_deg)),
    rep("Acidogenesis", length(group_acidogenesis))
  )
)

# ------------------------------------------------------------------------------
# 2. Add pathway group information
# ------------------------------------------------------------------------------

plot_df <- pathway_ts_filtered %>%
  left_join(pathway_groups, by = "function.") %>%
  filter(!is.na(pathway_group)) %>%
  mutate(
    sample_group = str_to_title(sample_group),
    pathway_group = factor(
      pathway_group,
      levels = c("Methanogenesis", "VFA degradation", "Acidogenesis")
    )
  )

# ------------------------------------------------------------------------------
# 3. Simple line plots: one plot per pathway group, faceted by sample group
# ------------------------------------------------------------------------------

plot_one_pathway_group <- function(group_name) {
  plot_df %>%
    filter(pathway_group == group_name) %>%
    ggplot(aes(x = Day, y = abundance, colour = module_label, group = module_label)) +
    geom_line(linewidth = 1) +
    geom_point(size = 2) +
    
    facet_wrap(~ sample_group) +
    
    scale_y_continuous(
  trans = scales::pseudo_log_trans(base = 10),
  limits = c(0, 15000),
  breaks = c(0, 100, 500, 1000, 2500, 10000),
  labels = scales::comma
) +
    
    theme_bw() +
    labs(
      x = "Day",
      y = "Predicted pathway abundance",
      colour = "Pathway",
    ) +
    theme(
      strip.text = element_text(face = "bold", size = 17),
      legend.position = "right",
      axis.text.x = element_text(angle = 35, hjust = 1, size = 17),
    axis.text.y = element_text(size = 16),
    axis.title = element_text(size = 19),
    legend.title = element_text(face = "bold", size = 18),
    legend.text = element_text(size = 17),
    )
}

p_methanogenesis <- plot_one_pathway_group("Methanogenesis")
p_VFA_deg        <- plot_one_pathway_group("VFA degradation")
p_acidogenesis   <- plot_one_pathway_group("Acidogenesis")

ggsave("plots/new/methanogenesis_pathway_abundance.png", p_methanogenesis, width = 10.67, height = 5, dpi = 300)
ggsave("plots/new/vfa_degradation_pathway_abundance.png", p_VFA_deg, width = 12, height = 5, dpi = 300)
ggsave("plots/new/acidogenesis_pathway_abundance.png", p_acidogenesis, width = 18, height = 6, dpi = 300)


```
