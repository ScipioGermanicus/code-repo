# 1. Define the taxonomic levels to iterate through
tax_levels <- c("phylum", "class", "order", "family", "genus", "species")

cat_levels <- c(
  "Already in MiDAS AD Genome DB",
  "Added by both samples",
  "Added by mesophilic sample only",
  "Added by thermophilic sample only"
)

# 2. Function to categorise taxa at each level
get_taxa_contributions <- function(df, level) {
  chj_taxa    <- df %>% filter(source == "chj")    %>% pull(!!sym(level)) %>% unique()
  meso_taxa   <- df %>% filter(source == "meso")   %>% pull(!!sym(level)) %>% unique()
  thermo_taxa <- df %>% filter(source == "thermo") %>% pull(!!sym(level)) %>% unique()

  chj_taxa    <- chj_taxa[!is.na(chj_taxa)]
  meso_taxa   <- meso_taxa[!is.na(meso_taxa)]
  thermo_taxa <- thermo_taxa[!is.na(thermo_taxa)]

  all_taxa <- unique(c(chj_taxa, meso_taxa, thermo_taxa))

  tibble(taxon = all_taxa) %>%
    mutate(
      category = case_when(
        taxon %in% chj_taxa ~ "Already in MiDAS AD Genome DB",
        taxon %in% meso_taxa & taxon %in% thermo_taxa ~ "Added by both samples",
        taxon %in% meso_taxa ~ "Added by mesophilic sample only",
        taxon %in% thermo_taxa ~ "Added by thermophilic sample only",
        TRUE ~ "Other"
      )
    ) %>%
    filter(category %in% cat_levels) %>%
    count(category, name = "n") %>%
    mutate(level = level)
}

# 3. Process the data
plot_data <- map_dfr(tax_levels, ~get_taxa_contributions(tax_all, .x)) %>%
  mutate(
    level = factor(level, levels = rev(tax_levels)),
    category = factor(category, levels = cat_levels)
  ) %>%
  complete(level, category, fill = list(n = 0))

# 4. Construct the plot
a <- ggplot(plot_data, aes(x = level, y = n, fill = category)) +
  geom_col(width = 0.7, color = "white", linewidth = 0.2) +
  coord_flip() +

  scale_fill_manual(
    values = c(
      "Already in MiDAS AD Genome DB" = "#e0e0e0",
      "Added by both samples" = "#5e3c99",
      "Added by mesophilic sample only" = "#2c7bb6",
      "Added by thermophilic sample only" = "#abd9e9"
    ),
    breaks = cat_levels,
    drop = FALSE
  ) +

  guides(
    fill = guide_legend(
      override.aes = list(alpha = 1, colour = NA)
    )
  ) +

  theme_minimal(base_size = 14) +
  labs(
    x = NULL,
    y = "Number of Unique Taxa",
    fill = "Source of Taxon"
  ) +
  theme(
    legend.position = "bottom",
    panel.grid.major.y = element_blank(),
    panel.grid.minor = element_blank(),
    axis.text = element_text(color = "black", face = "bold"),
    plot.title = element_text(face = "bold", size = 16),
    plot.subtitle = element_text(color = "grey30"),
    legend.title = element_text(face = "bold")
  ) +

  shadowtext::geom_shadowtext(
    data = plot_data %>% filter(category != "Already in MiDAS AD Genome DB", n > 0),
    aes(label = n),
    position = position_stack(vjust = 0.5),
    colour = "white",
    bg.colour = "black",
    bg.r = 0.18,
    size = 3,
    fontface = "bold"
  )


ggsave("added_taxa.png", a, width = 10, height = 4, dpi = 300)


