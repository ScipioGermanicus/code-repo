# Create one big tax file
make_tax_df <- function(df, source_name) {
  df %>%
    transmute(
      MAG = user_genome,
      source = source_name,
      classification = classification
    ) %>%
    separate(
      classification,
      into = c("domain", "phylum", "class", "order", "family", "genus", "species"),
      sep = ";",
      fill = "right",
      remove = FALSE
    ) %>%
    mutate(
      across(
        c(domain, phylum, class, order, family, genus, species),
        ~ str_remove(.x, "^[a-z]__")
      )
    )
}

