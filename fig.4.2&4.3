  left_join(ko_rel_abun, by = "KO") %>%
  mutate(
    ko_rel_abun = replace_na(ko_rel_abun, 0),
    enzyme_col = unname(group_cols[enzyme_group])
  ) %>%
  arrange(x) %>%
  mutate(
    axis_label = paste0(
      "<b><span style='color:", enzyme_col, "; font-size:14pt;'>", enzyme, "</span></b>",
      "<br><span style='font-size:10pt; line-height:1.2; color:black;'>", KO, "</span>",
      "<br><span style='font-size:10pt; line-height:1.2; color:black;'>&Sigma; rel. abun. = ",
      sprintf("%.2f%%", ko_rel_abun), "</span>"
    )
  )

# ------------------------------------------------------------------------------
# 12. Tile map
# ------------------------------------------------------------------------------

p_meso_tile <- ggplot(long, aes(x = x, y = genome_label, fill = presence)) +
  geom_tile(color = "white", linewidth = 0.2) +
  geom_vline(
    data = sub_sep,
    aes(xintercept = x_sep),
    inherit.aes = FALSE,
    linewidth = 0.6,
    colour = "grey75"
  ) +
  facet_grid(. ~ class, scales = "free_x", space = "free_x") +
  scale_x_continuous(
    breaks = axis_df$x,
    labels = axis_df$axis_label,
    expand = c(0, 0)
  ) +
  scale_y_discrete(
    labels = function(x) {
      x <- gsub("'", "\\\\'", x)
      parse(text = paste0("italic('", x, "')"))
    }
  ) +
  scale_fill_gradient(low = "grey90", high = "black", breaks = c(0, 1)) +
  labs(x = "Gene (KO)", y = "Phylum / family / species", fill = "Presence") +
  theme_minimal() +
  theme(
    axis.text.x = ggtext::element_markdown(angle = 45, hjust = 1, vjust = 1, size = 12),
    axis.text.x.bottom = ggtext::element_markdown(angle = 45, hjust = 1, vjust = 1, size = 11),
    axis.text.y = element_text(size = 11),
    panel.spacing.x = unit(0.8, "lines"),
    panel.background = element_rect(fill = "grey98", colour = NA),
    panel.border = element_rect(fill = NA, colour = "grey60", linewidth = 0.9),
    strip.background = element_rect(fill = "grey90", colour = "grey60"),
    strip.text = element_text(face = "bold"),
    legend.title = element_text(face = "bold", size = 14),

    )

p_meso_tile

ggsave(
  filename = "pectin_EC/new/meso_c_filtered_midas_tax.png",
  plot = p_meso_tile,
  width = 21,
  height = 10,
  dpi = 300
)

# ------------------------------------------------------------------------------
# 13. Relative abundance heatbar
# ------------------------------------------------------------------------------

heatbar_df <- ko_genome_matrix_meso_tax %>%
  distinct(genome_label, rel_abun) %>%
  arrange(desc(rel_abun)) %>%
  mutate(
    genome_label = factor(genome_label, levels = genome_order),
    heatbar_x = "Rel. abun."
  )

p_meso_heatbar <- ggplot(
  heatbar_df,
  aes(
    x = heatbar_x,
    y = genome_label,
    fill = rel_abun
  )
) +
  geom_tile(color = "white", linewidth = 0.2) +
  scale_fill_gradient(
    low = "steelblue",
    high = "darkred",
    labels = scales::label_number(suffix = "%")
  ) +
  scale_y_discrete(
    labels = function(x) {
      x <- gsub("'", "\\\\'", x)
      parse(text = paste0("italic('", x, "')"))
    }
  ) +
  labs(
    x = NULL,
    y = NULL,
    fill = "Relative abundance (%)"
  ) +
  theme_minimal() +
  theme(
    axis.text.x = element_text(angle = 45, hjust = 1, vjust = 1, size = 14),
    axis.text.y = element_blank(),
    axis.ticks.y = element_blank(),
    panel.grid = element_blank(),
    panel.background = element_rect(fill = "grey98", colour = NA),
    panel.border = element_rect(fill = NA, colour = "grey60", linewidth = 0.9),
    legend.title = element_text(face = "bold", size = 14),
    legend.position = "right",
    plot.margin = margin(
      t = 10,
      r = 10,
      b = 0,
      l = 80
    )
  )

p_meso_heatbar

ggsave(
  filename = "pectin_EC/new/meso.png",
  plot = p_meso_heatbar,
  width = 3.75,
  height = 7.9,
  dpi = 300
)

