Barplot weighted NSTI
```{r}


weighted_nsti_summary <- weighted_nsti_all %>%
  group_by(plot_group, database, group) %>%
  summarise(
    mean_NSTI = mean(weighted_NSTI),
    sd_NSTI = sd(weighted_NSTI),
    .groups = "drop"
  )

ggplot(weighted_nsti_summary, aes(x = plot_group, y = mean_NSTI, fill = database)) +
  geom_col(width = 0.7, colour = "black") +
  geom_errorbar(
    aes(ymin = mean_NSTI - sd_NSTI, ymax = mean_NSTI + sd_NSTI),
    width = 0.2
  ) +
  labs(
    x = NULL,
    y = "Mean weighted NSTI",
    fill = "Database"
  ) +
  theme_bw() +
  theme(
    axis.text.x = element_text(angle = 45, hjust = 1, size = 10),
    panel.grid.major.x = element_blank(),
    plot.margin = margin(
  t = 10,
  r = 10,
  b = 30,
  l = 30
  ))

ggsave("plots/nsti_barplot.png", width = 6, height = 5, dpi = 300)


```

box plot over raw NSTI
```{r}

# ------------------------------------------------------------------------------
# Boxplot of OTU-level NSTI distributions
# ------------------------------------------------------------------------------

p_nsti_boxplot <- ggplot(
  nsti_all,
  aes(
    x = plot_group,
    y = metadata_NSTI,
    fill = database
  )
) +
  geom_boxplot(
  width = 0.7,
  colour = "black",
  outlier.shape = NA
) +
scale_y_continuous(trans = "pseudo_log") +
  labs(
    x = NULL,
    y = "OTU-level NSTI",
    fill = "Database",
  ) +
  theme_bw(base_size = 12) +
  theme(
    axis.text.x = element_text(angle = 45, hjust = 1, size = 10),
    panel.grid.major.x = element_blank(),
    legend.position = "right",
    legend.title = element_text(face = "bold"),
    plot.title = element_text(face = "bold"),
    plot.margin = margin(
  t = 10,
  r = 10,
  b = 30,
  l = 30
)
  ) +
  scale_y_continuous(limits = c(0, 1.3))

p_nsti_boxplot

ggsave(
  filename = "plots/otu_level_nsti_boxplot.png",
  plot = p_nsti_boxplot,
  width = 5,
  height = 5.05,
  dpi = 300
)

